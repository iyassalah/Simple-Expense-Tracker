DATABASE_URL=postgresql://postgres:password@localhost:5432/qashio_points
PORT=3000

# Comma-separated browser origins allowed to call the API (CORS). Example for Docker Compose frontend on host port 4000:
# CORS_ORIGIN=http://localhost:4000

# Auth (JWT access + httpOnly refresh cookie)
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_SEC=604800
AUTH_REFRESH_COOKIE_NAME=refreshToken
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
